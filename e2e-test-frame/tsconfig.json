{
	"compilerOptions": {
		"target": "es2022",
		"module": "commonjs",
		"lib": ["es2022", "dom"],
		"esModuleInterop": true,
		"strict": true,
		"moduleResolution": "node",
		"resolveJsonModule": true,
		"sourceMap": true,
		"outDir": "dist",
		"rootDir": "./",
		"skipLibCheck": true,
		"types": ["node", "@playwright/test"]
	},
	"include": ["src/**/*.ts", "cucumber.js"],
	"exclude": ["node_modules"]
}
