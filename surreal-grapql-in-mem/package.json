{
  "name": "surreal-graphql-in-mem",
  "version": "1.0.0",
  "description": "SurrealDB + GraphQL + Vitest E2E with Testcontainers",
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:e2e": "vitest run",
    "test:stress": "vitest run --config vitest.stress.config.ts",
    "test:all": "vitest run --config vitest.config.ts && vitest run --config vitest.stress.config.ts",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@apollo/server": "^4.11.0",
    "graphql": "^16.9.0",
    "surrealdb": "^1.0.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "testcontainers": "^10.14.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=18"
  }
}
