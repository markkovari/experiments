# justfile

# Default recipe (optional)
default:
    @just --list

# Run the server and let host/port to be setup
runserver host="127.0.0.1" port="8000":
    uv run python manage.py runserver {{ host }}:{{ port }}

# Run database docker
start-docker-db:
    docker compose up -d --force-recreate --build db

# Run the whole app with docker compose
start-docker:
    docker compose up -d --force-recreate --build

# Run run-migrations
run-migrations:
    docker compose run --rm backend python -c "import os" && python manage.py migrate

# Run run-migrations
run-printenv:
    docker compose run --rm backend python -e "os.get"

# Create superuser
create-superuser:
    docker compose run --rm backend python -c "import os" && python manage.py createsuperuser
