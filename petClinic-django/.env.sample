# Django settings
DEBUG=True
DJANGO_SECRET_KEY=change-me

# Postgres settings
POSTGRES_DB=${mydb:POSTGRES_DB}
POSTGRES_USER=${myuser:POSTGRES_USER}
POSTGRES_PASSWORD=${POSTGRES_PASSWORD:mypassword}
POSTGRES_URL=${POSTGRES_URL:db}
POSTGRES_PORT=${POSTGRES_PORT:5432}

# Django database URL format
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_URL}:${POSTGRES_PORT}/${POSTGRES_DB}
