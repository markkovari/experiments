# Database Configuration
# For local development with embedded RocksDB:
DATABASE_URL=rocksdb://./data/surrealdb

# For remote SurrealDB (docker-compose):
# DATABASE_URL=http://surrealdb:8000
# DATABASE_USERNAME=root
# DATABASE_PASSWORD=root

# Server Configuration
PORT=3000

# Logging
RUST_LOG=info

# JWT Authentication (12-factor config)
# IMPORTANT: Change JWT_SECRET in production to a secure random string (min 32 characters)
JWT_SECRET=your-secret-key-change-this-in-production-min-32-chars
JWT_EXPIRATION=3600
