# Distributed AI Coding Agent Configuration
# Copy this file to .env and fill in your values

#===============================================================================
# TAILSCALE CONFIGURATION
#===============================================================================

# Tailscale auth key (generate at https://login.tailscale.com/admin/settings/keys)
# Use a reusable key for multiple devices
TAILSCALE_KEY=tskey-auth-xxxxxxxxxxxxxxxx

# Your Tailscale network name (found in admin console)
# Used for constructing DNS names like: device.tailnet-name.ts.net
TAILNET_NAME=tailnet-name

#===============================================================================
# NOMAD CONFIGURATION
#===============================================================================

# Nomad server address (set on client machines)
# Replace with your RPi's Tailscale hostname
NOMAD_SERVER=rpi5-control.tailnet-name.ts.net

# Nomad HTTP address for CLI and API
NOMAD_ADDR=http://rpi5-control.tailnet-name.ts.net:4646

# Datacenter name (must match across all nodes)
DATACENTER=home

#===============================================================================
# CONSUL CONFIGURATION
#===============================================================================

# Consul HTTP address
CONSUL_HTTP_ADDR=http://localhost:8500

# Consul server for client nodes to join
CONSUL_SERVER=rpi5-control.tailnet-name.ts.net

#===============================================================================
# OLLAMA CONFIGURATION
#===============================================================================

# Ollama host binding (0.0.0.0 for network access)
OLLAMA_HOST=0.0.0.0:11434

# Allow cross-origin requests
OLLAMA_ORIGINS=*

# Number of parallel inference requests
OLLAMA_NUM_PARALLEL=2

# Keep models loaded in memory
OLLAMA_KEEP_ALIVE=5m

# Default model for inference
OLLAMA_DEFAULT_MODEL=codellama:34b

#===============================================================================
# CLAUDE-FLOW CONFIGURATION
#===============================================================================

# Claude-Flow configuration file path
CLAUDE_FLOW_CONFIG=/opt/claude-flow/config.json

# Server ports
CLAUDE_FLOW_PORT=8080
CLAUDE_FLOW_MCP_PORT=8081

# Logging level (debug, info, warn, error)
LOG_LEVEL=info

# Node.js environment
NODE_ENV=production

#===============================================================================
# AGENT TASK CONFIGURATION
#===============================================================================

# Default resources for agent tasks
AGENT_CPU=4000
AGENT_MEMORY=8192

# Default task timeout
AGENT_TIMEOUT=30m

# Maximum concurrent agent tasks
MAX_CONCURRENT_AGENTS=4

#===============================================================================
# MODELS TO PULL (used by pull-models.sh)
#===============================================================================

# Comma-separated list of models
MODELS=codellama:34b,deepseek-coder:33b,llama3.2:70b,qwen2.5-coder:32b

# Include optional smaller models (true/false)
INCLUDE_OPTIONAL_MODELS=false

#===============================================================================
# PATHS (adjust for your system)
#===============================================================================

# Data directories
NOMAD_DATA_DIR=/opt/nomad/data
CONSUL_DATA_DIR=/opt/consul/data
CLAUDE_FLOW_DATA_DIR=/opt/claude-flow/data

# Log directories
NOMAD_LOG_DIR=/var/log
CONSUL_LOG_DIR=/var/log
CLAUDE_FLOW_LOG_DIR=/opt/claude-flow/logs

# Workspace directory for agent tasks
WORKSPACE_DIR=/Users/YOUR_USERNAME/workspaces
