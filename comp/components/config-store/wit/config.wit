// config:store — generic runtime application-config capability.
//
// The sibling of feature-flags: where flags answer "is behaviour X on for this
// context", config:store holds *typed values* an app reads at runtime —
// timeouts, limits, URLs, tunables — that ops wants to change without a
// redeploy. Distinct from wasi:config (which is host-injected, read-only, set
// at deploy): this is a *writable, versioned* store the app itself manages.
//
// Values are typed (string / int / bool / float / json) so callers don't
// reparse, every write bumps a monotonic version for optimistic concurrency +
// cache invalidation, and a namespace scopes keys per tenant/service. Pure WASI
// imports (keyvalue + clock).
package config:store@0.1.0;

/// Read and write typed, versioned runtime configuration values.
interface store {
    /// Why a config call failed.
    variant config-error {
        /// No value set for the given namespace + key.
        not-found,
        /// The stored value could not be parsed as the requested type.
        type-mismatch(string),
        /// A `put` failed because `expected-version` did not match the current
        /// version (optimistic-concurrency conflict). Carries the actual
        /// current version.
        version-conflict(u32),
        /// A backing dependency (the record store) was unreachable.
        backend-unavailable(string),
    }

    /// A typed configuration value.
    variant value {
        text(string),
        integer(s64),
        boolean(bool),
        decimal(f64),
        /// Raw JSON, stored/returned verbatim for structured config.
        json(string),
    }

    /// A value plus its version + last-write time.
    record entry {
        value: value,
        /// Monotonic version, bumped on every write; 1-based.
        version: u32,
        /// Unix seconds of the last write.
        updated: u64,
    }

    /// Fetch a typed value. `err(not-found)` if unset.
    get: func(namespace: string, key: string) -> result<entry, config-error>;

    /// Set a value unconditionally (overwrite), bumping the version. Returns the
    /// new version.
    set: func(namespace: string, key: string, value: value)
        -> result<u32, config-error>;

    /// Compare-and-set: only write if the current version equals
    /// `expected-version` (use 0 to mean "must not exist yet"). On mismatch,
    /// `err(version-conflict(current))`. Returns the new version on success.
    set-if: func(namespace: string, key: string, value: value, expected-version: u32)
        -> result<u32, config-error>;

    /// Delete a key. Idempotent. Returns true if a value was actually removed.
    delete: func(namespace: string, key: string) -> result<bool, config-error>;

    /// List all key names in a namespace, up to `max`.
    keys: func(namespace: string, max: u32) -> result<list<string>, config-error>;
}

/// What `config-store` provides: the store interface, backed by key-value +
/// clock. No required config knobs.
world config-store {
    export store;
    import wasi:keyvalue/store@0.2.0-draft;
    import wasi:clocks/wall-clock@0.2.0;
}
