// secrets:vault — generic secret storage + envelope-encryption capability.
//
// Every app holds secrets (API keys, signing keys, DB creds) that must not sit
// in plaintext in the same store as ordinary data. This component is the
// minimal vault: secrets are stored *envelope-encrypted* — each secret value is
// sealed under a per-vault data key, and only ciphertext touches the key-value
// backend. Callers get put / get / rotate / delete plus versioning, so a key
// rotation keeps old versions decryptable until consumers cut over.
//
// The master key comes from config (wasi:config) — injected by the host /
// deployment, never persisted by the component. AEAD is ChaCha20-Poly1305
// (pure-Rust, wasm-clean). Pure WASI imports otherwise.
package secrets:vault@0.1.0;

/// Store, retrieve, version and rotate envelope-encrypted secrets.
interface vault {
    /// Why a vault call failed.
    variant vault-error {
        /// No secret (or no such version) for the given name.
        not-found,
        /// The master key is missing/!32 bytes, or a stored value failed to
        /// decrypt/authenticate (tampering or wrong key).
        crypto(string),
        /// A backing dependency (the record store) was unreachable.
        backend-unavailable(string),
    }

    /// Metadata about a stored secret (never includes the plaintext).
    record secret-meta {
        /// Logical secret name.
        name: string,
        /// Current (highest) version number; 1-based.
        version: u32,
        /// Unix seconds the current version was written.
        updated: u64,
    }

    /// Store (or overwrite) a secret value, creating version 1 or bumping to the
    /// next version. The plaintext is AEAD-sealed before it touches the store.
    /// Returns the metadata for the new version.
    put: func(name: string, value: list<u8>) -> result<secret-meta, vault-error>;

    /// Decrypt and return the current version of a secret's plaintext.
    get: func(name: string) -> result<list<u8>, vault-error>;

    /// Decrypt and return a specific historical version (for rotation overlap).
    get-version: func(name: string, version: u32) -> result<list<u8>, vault-error>;

    /// Metadata for the current version without decrypting the value.
    describe: func(name: string) -> result<secret-meta, vault-error>;

    /// Rotate a secret: write `new-value` as a new version, keeping prior
    /// versions retrievable via `get-version`. Convenience over `put` that
    /// returns both the new and the immediately-previous version numbers.
    rotate: func(name: string, new-value: list<u8>)
        -> result<tuple<u32, u32>, vault-error>;

    /// Permanently delete a secret and all its versions. Idempotent.
    delete: func(name: string) -> result<_, vault-error>;

    /// List the names of all stored secrets (no values), up to `max`.
    list-names: func(max: u32) -> result<list<string>, vault-error>;
}

/// What `secrets-vault` provides: the vault interface, backed by key-value +
/// clock + random, with an AEAD master key from config. Config:
/// `master-key` (base64, 32 bytes — required).
world secrets-vault {
    export vault;
    import wasi:keyvalue/store@0.2.0-draft;
    import wasi:clocks/wall-clock@0.2.0;
    import wasi:random/random@0.2.0;
    import wasi:config/runtime@0.2.0-draft;
}
