# Copy to .env and adjust. Consumed by auth-guard config (set into kv) and by
# the Justfile when seeding config.

# --- NATS (wasi:keyvalue backend) ---
NATS_URL=nats://127.0.0.1:4222
KV_BUCKET=auth

# --- OIDC issuer (pick the one matching your compose profile) ---
# Zitadel profile:
OIDC_ISSUER=http://localhost:8080
# Ory (Hydra) profile:
# OIDC_ISSUER=http://localhost:4444

# OAuth client registered with the IdP (for oidc.exchange-code):
OIDC_CLIENT_ID=replace-me
OIDC_CLIENT_SECRET=replace-me

# --- Local HS256 secret (dev tokens, optional) ---
# When set, lets you mint test JWTs without a live IdP.
HS256_SECRET=dev-only-shared-secret-change-me

# How long (seconds) to cache OIDC discovery + JWKS in kv.
JWKS_CACHE_TTL=3600
