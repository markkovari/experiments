{
  "name": "comp-jco-vet-clinic-example",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A vet-clinic full-stack app (frontend + backend) composed only from comp capability components, run in-process via jco",
  "scripts": {
    "transpile:auth": "jco transpile auth_guard.composed.wasm -o gen/auth --map wasi:keyvalue/store@0.2.0-draft=../../src/shims/keyvalue.js --map wasi:keyvalue/atomics@0.2.0-draft=../../src/shims/keyvalue.js --map wasi:config/runtime@0.2.0-draft=../../src/shims/config.js",
    "transpile:session": "jco transpile session_store.wasm -o gen/session --map wasi:keyvalue/store@0.2.0-draft=../../src/shims/keyvalue.js --map wasi:config/runtime@0.2.0-draft=../../src/shims/config.js",
    "transpile:search": "jco transpile search_index.wasm -o gen/search --map wasi:keyvalue/store@0.2.0-draft=../../src/shims/keyvalue.js",
    "transpile:validate": "jco transpile validate.wasm -o gen/validate",
    "transpile:config": "jco transpile config_store.wasm -o gen/config --map wasi:keyvalue/store@0.2.0-draft=../../src/shims/keyvalue.js",
    "transpile:notify": "jco transpile notify_dispatch.wasm -o gen/notify --map wasi:config/runtime@0.2.0-draft=../../src/shims/config.js",
    "transpile": "npm run transpile:auth && npm run transpile:session && npm run transpile:search && npm run transpile:validate && npm run transpile:config && npm run transpile:notify",
    "start": "npm run transpile && tsx src/server.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run transpile && tsx --test test/**/*.test.ts"
  },
  "dependencies": {
    "@bytecodealliance/jco": "^1.23.0",
    "@bytecodealliance/preview2-shim": "^0.17.0",
    "@fastify/static": "^8.0.0",
    "fastify": "^5.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
