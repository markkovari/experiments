{
  "name": "comp-jco-vet-clinic-example",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A vet-clinic full-stack app (frontend + backend) composed only from comp capability components, run in-process via jco",
  "scripts": {
    "transpile:auth": "jco transpile auth_guard.composed.wasm -o gen/auth --map wasi:keyvalue/store@0.2.0-draft=../../src/shims/keyvalue.js --map wasi:keyvalue/atomics@0.2.0-draft=../../src/shims/keyvalue.js --map wasi:config/runtime@0.2.0-draft=../../src/shims/config.js",
    "transpile:session": "jco transpile session_store.wasm -o gen/session --map wasi:keyvalue/store@0.2.0-draft=../../src/shims/keyvalue.js --map wasi:config/runtime@0.2.0-draft=../../src/shims/config.js",
    "transpile:search": "jco transpile search_index.wasm -o gen/search --map wasi:keyvalue/store@0.2.0-draft=../../src/shims/keyvalue.js",
    "transpile:validate": "jco transpile validate.wasm -o gen/validate",
    "transpile:config": "jco transpile config_store.wasm -o gen/config --map wasi:keyvalue/store@0.2.0-draft=../../src/shims/keyvalue.js",
    "transpile:notify": "jco transpile notify_dispatch.wasm -o gen/notify --map wasi:config/runtime@0.2.0-draft=../../src/shims/config.js",
    "transpile:blob": "jco transpile blob_store.wasm -o gen/blob --map wasi:keyvalue/store@0.2.0-draft=../../src/shims/keyvalue.js",
    "transpile:upload": "jco transpile upload_policy.wasm -o gen/upload --map wasi:config/runtime@0.2.0-draft=../../src/shims/config.js",
    "transpile:fsm": "jco transpile fsm_workflow.wasm -o gen/fsm --map wasi:keyvalue/store@0.2.0-draft=../../src/shims/keyvalue.js",
    "transpile:money": "jco transpile money.wasm -o gen/money",
    "transpile:markdown": "jco transpile markdown.wasm -o gen/markdown",
    "transpile:csv": "jco transpile csv.wasm -o gen/csv",
    "transpile:pii": "jco transpile pii_redact.wasm -o gen/pii",
    "transpile:otp": "jco transpile otp.wasm -o gen/otp",
    "transpile:pagination": "jco transpile pagination.wasm -o gen/pagination --map wasi:config/runtime@0.2.0-draft=../../src/shims/config.js",
    "transpile:i18n": "jco transpile i18n_catalog.wasm -o gen/i18n --map wasi:keyvalue/store@0.2.0-draft=../../src/shims/keyvalue.js --map wasi:config/runtime@0.2.0-draft=../../src/shims/config.js",
    "transpile:record": "jco transpile record_store.wasm -o gen/record --map wasi:keyvalue/store@0.2.0-draft=../../src/shims/keyvalue.js",
    "transpile": "npm run transpile:auth && npm run transpile:session && npm run transpile:search && npm run transpile:validate && npm run transpile:config && npm run transpile:notify && npm run transpile:blob && npm run transpile:upload && npm run transpile:fsm && npm run transpile:money && npm run transpile:markdown && npm run transpile:csv && npm run transpile:pii && npm run transpile:otp && npm run transpile:pagination && npm run transpile:i18n && npm run transpile:record",
    "build:frontend": "cd frontend && npm install && npm run build",
    "start": "npm run transpile && tsx src/server.ts",
    "dev:frontend": "cd frontend && npm run dev",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run transpile && tsx --test test/**/*.test.ts"
  },
  "dependencies": {
    "@bytecodealliance/jco": "^1.23.0",
    "@bytecodealliance/preview2-shim": "^0.17.0",
    "@fastify/static": "^8.0.0",
    "fastify": "^5.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
