  },
  "dependencies": {
    "@bytecodealliance/jco": "^1.23.0",
    "@bytecodealliance/preview2-shim": "^0.17.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
