{
	"compilerOptions": {
		"outDir": "dist",
		"declaration": true,
		"declarationMap": true,
		"emitDeclarationOnly": false,
		"module": "ESNext",
		"target": "ES2019",
		"moduleResolution": "bundler",
		"esModuleInterop": true,
		"strict": true,
		"skipLibCheck": true
	},
	"include": [
		"database.ts",
		"schema.ts"
	]
}