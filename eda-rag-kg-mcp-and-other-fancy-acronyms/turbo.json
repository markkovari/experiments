{
  "$schema": "https://turborepo.com/schema.json",
  "tasks": {
    "build": {
      "outputs": [
        ".next/**",
        "dist/**"
      ]
    },
    "test:e2e": {
      "dependsOn": [
        "^build"
      ],
      "cache": false,
      "persistent": false
    },
    "check": {
      "cache": true
    },
    "check:write": {
      "cache": true
    },
    "check:unsafe": {
      "cache": true
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": [
        "^build"
      ]
    }
  }
}