          }
        }
      },
      "gridPos": { "h": 3, "w": 5, "x": 0, "y": 12 },
      "id": 15,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(gnatsd_varz_jetstream_stats_storage)",
          "refId": "A"
