            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 80 }
            ]
          }
        }
      },
      "gridPos": { "h": 6, "w": 8, "x": 4, "y": 0 },
      "id": 17,
      "options": {
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(jetstream_stream_total_bytes) by (stream_name)",
          "legendFormat": "{{stream_name}}",
          "refId": "A"
        }
      ],
      "title": "Stream data size",
      "type": "timeseries"
    },
    {
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 0 }
        }
      },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 0 },
      "id": 20,
      "options": {
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(jetstream_stream_last_seq[$__rate_interval])) by (stream_name)",
          "legendFormat": "{{stream_name}}",
          "refId": "A"
        }
      ],
      "title": "Message Rate (per second)",
      "type": "timeseries"
    },
    {
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 0 }
        }
      },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 6 },
      "id": 25,
      "options": {
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(jetstream_consumer_num_pending) by (consumer_name)",
          "legendFormat": "{{consumer_name}}",
          "refId": "A"
        }
      ],
      "title": "Pending messages per consumer",
      "type": "timeseries"
    },
    {
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 0 }
        }
      },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 6 },
      "id": 24,
      "options": {
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(jetstream_stream_total_messages) by (stream_name)",
          "legendFormat": "{{stream_name}}",
          "refId": "A"
        }
      ],
      "title": "Stream message count",
      "type": "timeseries"
